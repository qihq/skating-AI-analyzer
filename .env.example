# -- AI 供应商 Key（可选） ---------------------------------------
# 推荐进系统后在「家长设置 -> API 设置」里创建模型实例并保存 Key。
# 如果你更习惯环境变量，也可以在这里填写；Qwen 可填写任意一个，
# 如果你习惯百炼官方示例，优先填 DASHSCOPE_API_KEY。
# QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_VISION_MODEL=qwen3.6-plus
QWEN_VISION_DAILY_COST_LIMIT_CNY=30
QWEN_VISION_VIDEO_ESTIMATED_COST_CNY=0.6
# VIDEO_TEMPORAL_MAX_FRAMES=12
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- 安全密钥（必填，用于加密存储 API Key） ----------------------
# 建议使用 32 位随机字符串，或 32 位十六进制字符串
SECRET_KEY=replace-with-a-random-32-char-secret

# -- 可选：覆盖默认值 --------------------------------------------
# FRAME_SAMPLE_COUNT=20
# FRAME_THUMB_SIZE=160x90
# FRAME_FULL_SIZE=854x480
# MAX_UPLOAD_SIZE_MB=500
# DATA_DIR=/data
# DATABASE_URL=sqlite+aiosqlite:////data/skating-analyzer.db
# MEDIAPIPE_POSE_TASK_PATH=/models/pose_landmarker_heavy.task
# YOLO_PERSON_MODEL_PATH=/models/yolov8n.pt
# POSE_NUM_POSES=4
